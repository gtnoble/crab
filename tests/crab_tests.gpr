with "config/crab_tests_config.gpr";
project Crab_Tests is

   for Source_Dirs use ("src/", "config/");
   for Object_Dir use "obj/" & Crab_Tests_Config.Build_Profile;
   for Create_Missing_Dirs use "True";
   for Exec_Dir use "bin";
   for Main use ("crab_tests.adb");

   package Compiler is
      for Default_Switches ("Ada") use
        Crab_Tests_Config.Ada_Compiler_Switches;
   end Compiler;

   package Binder is
      for Switches ("Ada") use ("-Es");
   end Binder;

   package Linker is
      for Switches ("Ada") use ("-lz", "-llz4");
   end Linker;

end Crab_Tests;
