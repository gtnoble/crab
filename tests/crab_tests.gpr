with "config/crab_tests_config.gpr";
project Crab_Tests is

   --  Profiling scenario variable: alr build -- -XCRAB_PROFILING=true
   type Prof_Kind is ("false", "true");
   Prof : Prof_Kind := External ("CRAB_PROFILING", "false");

   --  Sanitizer scenario variable: alr build -- -XCRAB_SANITIZE=true
   type San_Kind is ("false", "true");
   San : San_Kind := External ("CRAB_SANITIZE", "false");

   Ada_Profiling_Switches := Crab_Tests_Config.Ada_Compiler_Switches &
          (
            "-Og" -- Optimize for debugging
           ,"-pg" -- Profile generation (gprof)
           ,"-ffunction-sections" -- Separate ELF section for each function
           ,"-fdata-sections" -- Separate ELF section for each variable
           ,"-g" -- Generate debug info
           ,"-gnatW8" -- UTF-8 encoding for wide characters
          );

   Ada_Sanitizer_Switches :=
          (
           "-fsanitize=address,undefined"  -- ASan + UBSan
          ,"-fno-omit-frame-pointer"       -- Better stack traces
          );

   for Source_Dirs use ("src/", "config/");
   case San is
      when "true" =>
         case Prof is
            when "true" => for Object_Dir use "obj/" & Crab_Tests_Config.Build_Profile & "-san-pg";
            when others => for Object_Dir use "obj/" & Crab_Tests_Config.Build_Profile & "-san";
         end case;
      when others =>
         case Prof is
            when "true" => for Object_Dir use "obj/" & Crab_Tests_Config.Build_Profile & "-pg";
            when others => for Object_Dir use "obj/" & Crab_Tests_Config.Build_Profile;
         end case;
   end case;
   for Create_Missing_Dirs use "True";
   for Exec_Dir use "bin";
   for Main use ("crab_tests.adb");

   package Compiler is
      case San is
         when "true" =>
            case Prof is
               when "true" => for Default_Switches ("Ada") use Ada_Profiling_Switches & Ada_Sanitizer_Switches;
               when others => for Default_Switches ("Ada") use Crab_Tests_Config.Ada_Compiler_Switches & Ada_Sanitizer_Switches;
            end case;
         when others =>
            case Prof is
               when "true" => for Default_Switches ("Ada") use Ada_Profiling_Switches;
               when others => for Default_Switches ("Ada") use Crab_Tests_Config.Ada_Compiler_Switches;
            end case;
      end case;
   end Compiler;

   package Binder is
      for Switches ("Ada") use ("-Es");
   end Binder;

   package Linker is
      case San is
         when "true" =>
            case Prof is
               when "true" => for Switches ("Ada") use ("-lz", "-llz4", "-llzma", "-fsanitize=address,undefined", "-pg");
               when others => for Switches ("Ada") use ("-lz", "-llz4", "-llzma", "-fsanitize=address,undefined");
            end case;
         when others =>
            case Prof is
               when "true" => for Switches ("Ada") use ("-lz", "-llz4", "-llzma", "-pg");
               when others => for Switches ("Ada") use ("-lz", "-llz4", "-llzma");
            end case;
      end case;
   end Linker;

end Crab_Tests;
